<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Zinc_Code.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:AvaloniaEdit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="Zinc_Code.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Zinc Code">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid x:Name="ContentPagePane">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.75*" />
            <ColumnDefinition Width="0.125*" />
            <ColumnDefinition Width="0.125*" />
        </Grid.ColumnDefinitions>
        <AvaloniaEdit:TextEditor Grid.Column="0" x:Name="Code"
                          ShowLineNumbers="True"
                          FontFamily="Fira Code, Cascadia Code, JetBrains Mono, monospace, Consolas"
                          FontSize="16"
                          FontWeight="DemiBold"
                          Background="#1e1e1e"
                          Foreground="#dcdcdc"
                          Document="{Binding Document,Mode=TwoWay}"
                          />
        <Button Grid.Column="1" Content="Open" Command="{Binding ReadCodeCommand}"/>
        <Button Grid.Column="2" Content="Save" Command="{Binding SaveCodeCommand}"/>
     </Grid>
    
</Window>
